{
  "compilerOptions": {
    "allowJs": false,
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node"]
  },
  "include": [
    "content/**/*.json",
    "scripts/**/*.ts",
    "src/**/*.ts"
  ],
  "exclude": ["src/**/*.test.ts"]
}
