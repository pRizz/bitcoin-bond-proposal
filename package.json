{
	"name": "bitcoin-bond-proposal",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.3.9",
	"scripts": {
		"build": "vinxi build",
		"build:pdf": "bun scripts/build-pdf.ts",
		"compile:content": "bun scripts/compile-content.ts",
		"dev": "vinxi dev",
		"format": "bunx @biomejs/biome format --write .",
		"format:check": "bunx @biomejs/biome check --formatter-enabled=true --linter-enabled=false --assist-enabled=false .",
		"hooks:install": "git config core.hooksPath .githooks",
		"lint": "bunx @biomejs/biome lint --error-on-warnings .",
		"precommit": "bun scripts/precommit.ts",
		"refresh:queue": "bun scripts/build-refresh-queue.ts",
		"start": "vinxi start",
		"test": "bun test",
		"validate:content": "bun scripts/validate-content.ts"
	},
	"dependencies": {
		"@solidjs/meta": "^0.29.4",
		"@solidjs/router": "^0.16.1",
		"@solidjs/start": "^1.3.2",
		"@tailwindcss/vite": "^4.2.2",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"gray-matter": "^4.0.3",
		"markdown-it": "^14.1.1",
		"playwright": "^1.58.2",
		"solid-js": "^1.9.12",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.2.2",
		"vinxi": "^0.5.11",
		"vite": "^8.0.3",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@types/markdown-it": "^14.1.2",
		"@types/node": "^25.5.0",
		"bun-types": "^1.3.11",
		"typescript": "^6.0.2"
	},
	"trustedDependencies": [
		"@parcel/watcher"
	]
